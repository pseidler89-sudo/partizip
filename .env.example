# Partizip — Umgebungsvariablen (Beispiel)
# Echte Werte NIEMALS in dieses File oder ins Repo committen.
# Kopiere diese Datei nach .env und fülle die Werte aus.

# ── Domains ──────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
TENANT_BASE_DOMAIN=localhost

# ── Single-Domain-Pilot (ADR-015) ────────────────────────────────────────────
# Leer lassen = klassisches Subdomain-Modell (<slug>.partizip.online), Haupt-
# Domain zeigt die neutrale Landing-Page.
# Gesetzt (z. B. "taunusstein") = die GESAMTE App läuft im Pilot unter der
# Haupt-Domain (partizip.online) und wird auf diesen Tenant aufgelöst — der
# Bürger steigt per PLZ/Standort ein (kein Subdomain nötig). Subdomains bleiben
# parallel nutzbar (Skalierungs-Roadmap).
PILOT_TENANT_SLUG=

# ── Absender (E-Mail) ─────────────────────────────────────────────────────────
MAIL_FROM_NAME=Partizip
MAIL_FROM_ADDRESS=noreply@partizip.online
MAIL_ADMIN_ADDRESS=admin@partizip.online

# ── SMTP (dev: Mailpit auf 127.0.0.1:1025; prod: echter SMTP-Server) ─────────
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Auth (M2) ─────────────────────────────────────────────────────────────────
# Kein AUTH_SECRET nötig — eigene Magic-Link-Auth ohne JWT (ADR-006)
# SMTP_URL alternativ zu SMTP_HOST/PORT (wird in M2 bevorzugt)
SMTP_URL=smtp://127.0.0.1:1025
EMAIL_FROM=Partizip <noreply@partizip.online>

# TTL des Magic-Links in Minuten (Standard: 15)
MAGIC_LINK_TTL_MIN=15
# TTL der Session in Tagen (Standard: 30)
SESSION_TTL_DAYS=30

# ── Datenbank ─────────────────────────────────────────────────────────────────
# Dev-Postgres läuft auf Port 5433 (nicht 5432, da Port belegt)
DATABASE_URL=postgres://partizip:partizip@127.0.0.1:5433/partizip
DATABASE_URL_TEST=postgres://partizip:partizip@127.0.0.1:5433/partizip_test

# ── Datenschutz / Hashing ─────────────────────────────────────────────────────
# IP_HASH_SALT: HMAC-Salt für IP-/Rate-Limit-Hashing (openssl rand -base64 32).
# PFLICHT in NODE_ENV=production — FAIL-CLOSED: ohne Salt wirft hashIp()/
# hmacRateLimit() hart (app/src/lib/auth/crypto.ts), d. h. der Prod-Start mit dem
# Platzhalter unten schlägt Auth/Rate-Limit fehl. Pre-Flight prüfen:
#   [ -n "$IP_HASH_SALT" ] && [ "$IP_HASH_SALT" != REPLACE_WITH_RANDOM_SALT ]
IP_HASH_SALT=REPLACE_WITH_RANDOM_SALT
# (UA_HASH_SALT entfernt: User-Agent-Hashing ist nicht implementiert — war toter Eintrag.)

# ── Testing / Entwicklung ─────────────────────────────────────────────────────
# x-test-host Override: NUR in test/dev; NIEMALS in Produktion auf 1 setzen
# Erlaubt Tenant-Simulation via HTTP-Header für Integrationstests
ALLOW_TEST_HOST_OVERRIDE=

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_PASSKEYS=false
FEATURE_GUIDED_ONBOARDING=true

# ── Pseudonymisierung: ANLIEGEN_REF_SALT ──────────────────────────────────────
# HMAC-Salt für creator_ref (Anliegen) UND voter_ref (Abstimmungen, Salt wird
# wiederverwendet). PFLICHT in ALLEN Umgebungen — fail-closed (creator-ref.ts/
# voter-ref.ts werfen ohne Salt). IRREVERSIBEL: nach Launch NIE ändern — ein
# anderer Salt bricht den Doppelstimmen-Schutz (UNIQUE poll_id,voter_ref) und die
# Anliegen-Zuordnung. DR-relevant: separat sichern — ein DB-Restore OHNE identischen
# Salt macht alle voter_ref/creator_ref wertlos. Mindestens 32 Zeichen: openssl rand -base64 32
ANLIEGEN_REF_SALT=REPLACE_WITH_RANDOM_SALT

# ── M7 Digest-Pipeline ────────────────────────────────────────────────────────
# RIS-Scraping: User-Agent für robots.txt-konforme Anfragen
# Standard: "PartizipBot/0.1 (+https://partizip.online; kontakt folgt)"
RIS_USER_AGENT=PartizipBot/0.1 (+https://partizip.online; kontakt folgt)

# ── Kanäle (ADR-021: souverän, offene Protokolle) ────────────────────────────
# Die EIGENE SEITE ist der Kanal — soziale Netze bekommen nur Anreißer + Permalink.
# Alle Werte optional: ohne Zugangsdaten ist der jeweilige Kanal ein No-op.
# Telegram/WhatsApp entfallen bewusst ersatzlos (Widerspruch zum Souveränitäts-
# Versprechen; siehe ADR-021).

# Mastodon / ActivityPub (PRIMÄR — W3C-Standard, Instanz frei wählbar).
# Token: Mastodon → Einstellungen → Entwicklung → Neue Anwendung, Scope: write:statuses
MASTODON_INSTANCE_URL=
MASTODON_ACCESS_TOKEN=

# Bluesky / AT-Protocol (sekundär — offenes Protokoll, aber US-Unternehmen).
# BLUESKY_APP_PASSWORD ist ein APP-Passwort (Einstellungen → App-Passwörter),
# NIEMALS das Konto-Passwort. Handle idealerweise per DNS-TXT verifiziert:
# TXT-Record auf _atproto.<handle-domain> mit Wert did=did:plc:<DID>
# (App-Passwort in den Konto-Einstellungen erzeugen; Handle per DNS-TXT _atproto verifizieren.)
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=
BLUESKY_SERVICE=https://bsky.social

# ── M7 KI-Digest-Generator (optional — Plattform funktioniert vollständig ohne KI) ──
# ANTHROPIC_API_KEY: Leer lassen = KI deaktiviert, extractive_v1 übernimmt automatisch.
# Niemals in Logs oder Fehlermeldungen ausgeben (wird serverseitig redacted).
ANTHROPIC_API_KEY=

# DIGEST_GENERATOR: Steuert welcher Generator verwendet wird.
#   auto          — llm_v2 wenn ANTHROPIC_API_KEY gesetzt, sonst extractive_v1 (Standard)
#   extractive_v1 — immer deterministisch, kein LLM
#   llm_v2        — immer LLM (erfordert ANTHROPIC_API_KEY; Fehler wenn Key fehlt)
DIGEST_GENERATOR=auto

# DIGEST_LLM_MODEL: Anthropic-Modell für Digest-Generierung.
# Standard: claude-haiku-4-5-20251001 (kostengünstig, schnell)
DIGEST_LLM_MODEL=claude-haiku-4-5-20251001

# DIGEST_LLM_MAX_TOKENS: Maximale Token-Anzahl für LLM-Antwort.
# Standard: 2000 (ausreichend für 30 Aussagen)
DIGEST_LLM_MAX_TOKENS=2000

# OPARL_MAX_PAGES: Wie viele Listenseiten der OParl-Adapter beim Import
# durchblättert (Default: 5) — siehe docs/manual/OPARL_UMSCHALTEN.md
OPARL_MAX_PAGES=5
